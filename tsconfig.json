{
  "extends": "@tsconfig/node16-strictest-esm/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node16",
    "baseUrl": ".",
    "types": [
      "node",
      "hapi__hapi"
    ],
    "sourceMap": true,
    "outDir": "./dist/",
    "isolatedModules": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
}
